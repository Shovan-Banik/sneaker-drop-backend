DB_HOST=localhost
DB_PORT=5432
DB_NAME=sneaker_drop
DB_USER=app_user
DB_PASS=secret

# Optional: a single DATABASE_URL can still be used and will take precedence
# DATABASE_URL=postgres://user:password@localhost:5432/sneaker_drop

PORT=3000
RESERVATION_TTL=60
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Optional: When creating tables you may need a superuser connection. Provide
# SUPERUSER_DATABASE_URL only for running the init script (don't use in runtime).
# SUPERUSER_DATABASE_URL=postgres://postgres:admin@localhost:5432/sneaker_drop
